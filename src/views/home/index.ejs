    .btn-gradient {
      background: linear-gradient(45deg, #00c6ff, #1D4268);
      color: #fff;
      border: none;
      font-weight: 600;
      transition: 0.3s;
    }

    .btn-gradient:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0, 114, 255, 0.4);
    }








    @keyframes glowRotate {
      0% {
        filter: hue-rotate(0deg);
      }

      100% {
        filter: hue-rotate(360deg);
      }
    }






    /* Animated Play Button */
    .play-btn {
      width: 70px;
      height: 70px;
      background: radial-gradient(circle, #ff0000, #990000);
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 28px;
      color: #fff;
      animation: pulse 1.5s infinite;
      box-shadow: 0 0 20px rgba(255, 0, 0, 0.8);
    }

    @keyframes pulse {
      0% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.15);
      }

      100% {
        transform: scale(1);
      }
    }

    .game-title {
      position: absolute;
      bottom: 10px;
      left: 50%;
      transform: translateX(-50%);
      color: #fff;
      font-weight: bold;
      background: rgba(0, 0, 0, 0.6);
      padding: 5px 15px;
      border-radius: 20px;
      font-size: 14px;
      letter-spacing: 1px;
    }
