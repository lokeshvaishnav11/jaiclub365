    <script>
            // Sidebar Logic
            const menuToggle = document.getElementById("menuToggle");
            const sidebar = document.getElementById("sidebar");
            const closeSidebar = document.getElementById("closeSidebar");
            const sidebarLoginLink = document.getElementById("sidebarLoginLink");

            if (menuToggle && sidebar && closeSidebar) {
              menuToggle.addEventListener("click", (e) => {
                e.stopPropagation();
                sidebar.classList.add("open");
              });
              closeSidebar.addEventListener("click", () =>
                sidebar.classList.remove("open")
              );
              document.addEventListener("click", (event) => {
                if (
                  sidebar &&
                  sidebar.classList.contains("open") &&
                  !sidebar.contains(event.target) &&
                  !menuToggle.contains(event.target)
                ) {
                  sidebar.classList.remove("open");
                }
              });
            }
            if (sidebarLoginLink) {
              sidebarLoginLink.addEventListener("click", (e) => {
                e.preventDefault();
                sidebar.classList.remove("open");
                setTimeout(() => {
                  $("#openLoginPopupBtn").trigger("click");
                }, 150);
              });
            }

            // Dummy Withdrawal Data Logic
            const dummyData = [
              { name: "isha S.", amount: "113645" },
              { name: "Sunil K.", amount: "98650" },
              { name: "neha M.", amount: "124300" },
              { name: "Pmit P.", amount: "75300" },
              { name: "Pooja R.", amount: "145600" },
              { name: "Om B.", amount: "84500" },
            ];
            let currentIndex = 0;
            const nameEl = document.getElementById("name");
            const withdrawalEl = document.getElementById("withdrawal");
            if (nameEl && withdrawalEl && dummyData.length > 0) {
              function updateWithdrawalDisplay() {
                const data = dummyData[currentIndex];
                $(nameEl).fadeOut(300, function () {
                  $(this).text(data.name).fadeIn(300);
                });
                $(withdrawalEl).fadeOut(300, function () {
                  $(this)
                    .text("₹ " + parseInt(data.amount).toLocaleString("en-IN"))
                    .fadeIn(300);
                });
                currentIndex = (currentIndex + 1) % dummyData.length;
              }
              updateWithdrawalDisplay();
              setInterval(updateWithdrawalDisplay, 3500);
            } else {
              if (nameEl) nameEl.innerText = "User";
              if (withdrawalEl) withdrawalEl.innerText = "₹ ---";
            }
          </script>

    <!-- 3. Combined Popup & Form Logic Script -->
    <script>
            $(document).ready(function () {
              // --- References ---
              const $loginPopupOverlay = $("#loginPopupOverlay");
              const $openLoginBtn = $("#openLoginPopupBtn");
              const $openRegisterBtn = $("#openRegisterPopupBtn");
              const $openLoginBtnPlay = $("#openLoginPopupBtnPlay");
              const $closeLoginBtn = $("#closeLoginPopupBtn");
              const $authFormContainer = $("#authFormContainer");
              const $loginView = $("#loginFormView");
              const $registerView = $("#registerFormView");
              const $forgotPasswordView = $("#forgotPasswordView"); // Added
              const $loadingOverlay = $(".van-overlay"); // Ensure class matches your loading overlay HTML

              // --- Function to Open Popup ---
              function openPopup(viewToShow = "login") {
                if (!$loginPopupOverlay.length) return;
                // Show/Hide Views
                $loginView.hide().removeClass("active");
                $registerView.hide().removeClass("active");
                $forgotPasswordView.hide().removeClass("active");

                if (viewToShow === "register" && $registerView.length) {
                  $registerView.show().addClass("active");
                  try {
                    var url = new URL(window.location.href);
                    var c = url.searchParams.get("r_code");
                    if (c) {
                      $registerView.find("#inviteCode").val(c);
                    }
                  } catch (e) { }
                } else if (viewToShow === "forgot" && $forgotPasswordView.length) {
                  $forgotPasswordView.show().addClass("active");
                } else {
                  // Default to login
                  $loginView.show().addClass("active");
                }
                // Clear previous alerts
                $authFormContainer.find(".alert-toast").empty().hide();
                // Clear form fields
                $authFormContainer
                  .find(
                    'input[type="text"], input[type="password"], input[type="number"]'
                  )
                  .val("");
                // Reset checkboxes
                $authFormContainer
                  .find(".van-checkbox")
                  .removeClass("checked")
                  .attr("aria-checked", "false");
                $authFormContainer
                  .find(".van-checkbox__icon")
                  .removeClass("van-checkbox__icon--checked");
                $authFormContainer.find(".van-checkbox__icon i").hide();
                $loginView
                  .find(".login-checkbox")
                  .addClass("checked")
                  .attr("aria-checked", "true");
                $loginView
                  .find(".login-checkbox .van-checkbox__icon")
                  .addClass("van-checkbox__icon--checked");
                $loginView.find(".login-checkbox .van-checkbox__icon i").show();
                // Reset OTP button if present in forgot view
                $forgotPasswordView
                  .find("#popupForgotOtpBtn")
                  .prop("disabled", false)
                  .removeClass("block-click")
                  .text("Send");
                // Clear any OTP intervals if necessary (get interval reference if needed)

                // Show overlay
                $loginPopupOverlay.css("display", "flex").hide().fadeIn(250);
              }

              // --- Event Handlers for Opening/Closing ---
              if ($openLoginBtn.length)
                $openLoginBtn.on("click", function (e) {
                  e.preventDefault();
                  openPopup("login");
                });
              if ($openRegisterBtn.length)
                $openRegisterBtn.on("click", function (e) {
                  e.preventDefault();
                  openPopup("register");
                });

              // Handler for register button in body section
              const $openRegisterBtnBody = $("#openRegisterPopupBtnBody");
              if ($openRegisterBtnBody.length)
                $openRegisterBtnBody.on("click", function (e) {
                  e.preventDefault();
                  openPopup("register");
                });

              if ($openLoginBtnPlay.length)
                $openLoginBtnPlay.on("click", function (e) {
                  e.preventDefault();
                  openPopup("login");
                });
              if ($closeLoginBtn.length)
                $closeLoginBtn.on("click", function () {
                  $loginPopupOverlay.fadeOut(200);
                });
              if ($loginPopupOverlay.length)
                $loginPopupOverlay.on("click", function (event) {
                  if ($(event.target).is($loginPopupOverlay)) {
                    $loginPopupOverlay.fadeOut(200);
                  }
                });

              // --- showPass Function ---
              window.showPass = function (inputId, iconId) {
                var visibleView = $authFormContainer.find(".form-view.active");
                var x = visibleView.find("#" + inputId)[0];
                var y = visibleView.find("#" + iconId)[0];
                if (x && y) {
                  if (x.type === "password") {
                    x.type = "text";
                    y.src = "/index_files/eyeVisible-7bc1c956.png";
                  } // CHECK PATH
                  else {
                    x.type = "password";
                    y.src = "/index_files/eyeInvisible-2fa5c152.png";
                  } // CHECK PATH
                } else if (x) {
                  console.warn("showPass: Eye icon #" + iconId + " not found.");
                } else {
                  console.error("showPass: Input #" + inputId + " not found.");
                }
              };

              // --- alertMessPopup Function ---
              function alertMessPopup(text) {
                const $alertToast = $authFormContainer.find(
                  ".form-view.active .alert-toast"
                );
                if ($alertToast.length === 0) {
                  alert(text);
                  return;
                }
                $alertToast.empty();
                const messageHtml = `<div class="msg"><div class="msg-content">${text}</div></div>`;
                $alertToast.append(messageHtml).hide().fadeIn(300);
              }

              // --- Cookie Functions ---
              function setCookie(cname, cvalue, exdays) {
                const d = new Date();
                d.setTime(d.getTime() + exdays * 24 * 60 * 60 * 1000);
                let expires = "expires=" + d.toUTCString();
                document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
              }

              // --- View Switching Logic ---
              if (
                $authFormContainer.length &&
                $loginView.length &&
                $registerView.length &&
                $forgotPasswordView.length
              ) {
                // Switch to Register (from Login)
                $authFormContainer.on("click", ".switchToRegister", function (e) {
                  e.preventDefault();
                  $loginView.fadeOut(150, function () {
                    $(this).removeClass("active");
                    $registerView.find(".alert-toast").empty().hide();
                    $registerView.fadeIn(150).addClass("active");
                  });
                });
                // Switch to Login (from Register or Forgot)
                $authFormContainer.on("click", ".switchToLogin", function (e) {
                  e.preventDefault();
                  var $currentView = $(this).closest(".form-view");
                  $currentView.fadeOut(150, function () {
                    $(this).removeClass("active");
                    $loginView.find(".alert-toast").empty().hide();
                    $loginView.fadeIn(150).addClass("active");
                  });
                });
                // Switch to Forgot Password (from Login)
                $authFormContainer.on("click", ".switchToForgot", function (e) {
                  e.preventDefault();
                  $loginView.fadeOut(150, function () {
                    $(this).removeClass("active");
                    $forgotPasswordView.find(".alert-toast").empty().hide();
                    $forgotPasswordView.fadeIn(150).addClass("active");
                  });
                });
              }

              // --- Checkbox Logic ---
              if ($authFormContainer.length) {
                $authFormContainer.on("click", ".van-checkbox", function (e) {
                  e.preventDefault();
                  var $checkbox = $(this);
                  var $icon = $checkbox.find(".van-checkbox__icon i");
                  var $iconContainer = $checkbox.find(".van-checkbox__icon");
                  if ($checkbox.hasClass("checked")) {
                    $checkbox.removeClass("checked").attr("aria-checked", "false");
                    $iconContainer.removeClass("van-checkbox__icon--checked");
                    $icon.hide();
                  } else {
                    $checkbox.addClass("checked").attr("aria-checked", "true");
                    $iconContainer.addClass("van-checkbox__icon--checked");
                    $icon.show();
                  }
                });
              }

              // --- LOGIN SUBMISSION LOGIC ---
              const $loginSubmitBtn = $("#popupLoginSubmitBtn");
              if ($loginSubmitBtn.length && $loginView.length) {
                $loginSubmitBtn.on("click", function (e) {
                  e.preventDefault();
                  $loginView.find(".alert-toast").empty().hide();
                  let username = $loginView
                    .find('input[name="username"]')
                    .val()
                    ?.trim();
                  let password = $loginView.find("#passwordfield").val()?.trim();
                  if (!username || !password) {
                    alertMessPopup("Phone number and password are required!");
                    return;
                  }
                  if (!/^\d{10}$/.test(username)) {
                    alertMessPopup("Please enter a valid 10-digit phone number.");
                    return;
                  }
                  if ($loadingOverlay.length) $loadingOverlay.fadeIn(10);
                  $.ajax({
                    type: "POST",
                    url: "/api/webapi/login",
                    data: { username: username, pwd: password },
                    dataType: "json",
                    success: function (response) {
                      if (response.status === true) {
                        setCookie("token", response.token, 1);
                        setCookie("auth", response.value, 1);

                        // Now, get the user info to check if admin or not
                        $.ajax({
                          type: "GET",
                          url: "/api/webapi/GetUserInfo",
                          dataType: "json",
                          success: function (userinfo) {
                            if (userinfo.status === true) {
                              if ($loadingOverlay.length) $loadingOverlay.fadeOut(100);
                              $loginPopupOverlay.fadeOut(200, function () {
                                if (userinfo.data.name_user === "Admin") {
                                  // If admin, redirect
                                  window.location.href = "/admin/manager/aviator";
                                } else {
                                  // If normal user, reload
                                  window.location.reload();
                                }
                              });
                            } else {
                              if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                              alertMessPopup(userinfo.message || "Failed to get user info.");
                            }
                          },
                          error: function () {
                            if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                            alertMessPopup("Error getting user info.");
                          }
                        });

                      } else {
                        if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                        alertMessPopup(response.message || "Invalid credentials.");
                      }
                    },
                    error: function (jqXHR) {
                      console.error("Login AJAX Error:", jqXHR.statusText);
                      if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                      alertMessPopup("Login failed. Please try again.");
                    }
                  });

                });
              }

              // --- REGISTRATION SUBMISSION LOGIC ---
              const $registerSubmitBtn = $("#popupRegisterSubmitBtn");
              if ($registerSubmitBtn.length && $registerView.length) {
                $registerSubmitBtn.on("click", function (e) {
                  e.preventDefault();
                  $registerView.find(".alert-toast").empty().hide();
                  let username = $registerView
                    .find('input[name="registerUsername"]')
                    .val()
                    ?.trim();
                  let password = $registerView
                    .find("#registerPassword")
                    .val()
                    ?.trim();
                  let invite = $registerView.find("#inviteCode").val()?.trim();
                  let isChecked = $registerView
                    .find(".register-checkbox")
                    .hasClass("checked");
                  let phone = $registerView.find("#registerPhone").val()?.trim();
                  if (!username || !password) {
                    alertMessPopup("Please fill in all required fields.");
                    return;
                  }

                  console.log(
                    username,
                    password,
                    phone,

                    "yjhkl;ghjklfghjknlmfghjknl"
                  );
                  //  if (!/^\d{10}$/.test(username)) { alertMessPopup("Please enter a valid 10-digit phone number."); return; }
                  //  if (!/^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d@$!%*?&.\/]{8,}$/.test(password)) { alertMessPopup("Password must be 8+ chars with letters & numbers."); return; }
                  //  if (!isChecked) { alertMessPopup("Please agree to the Privacy Agreement."); return; }
                  if ($loadingOverlay.length) $loadingOverlay.fadeIn(10);
                  $.ajax({
                    type: "POST",
                    url: "/api/webapi/register",
                    data: {
                      username: phone,
                      pwd: password,
                      invitecode: invite,
                      name: username,
                    },
                    dataType: "json",
                    success: function (response) {
                      if (response.status === true) {
                        if ($loadingOverlay.length) $loadingOverlay.fadeOut(100);
                        alertMessPopup(
                          response.message || "Registration successful! Please login."
                        );
                        setTimeout(() => {
                          $registerView.fadeOut(150, function () {
                            $(this).removeClass("active");
                            $loginView.find('input[name="username"]').val(username);
                            $loginView.find("#passwordfield").val("");
                            $loginView.find(".alert-toast").empty().hide();
                            $loginView.fadeIn(150).addClass("active");
                          });
                        }, 2000);
                      } else {
                        if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                        alertMessPopup(response.message || "Registration failed.");
                      }
                    },
                    error: function (jqXHR) {
                      console.error("Register AJAX Error:", jqXHR.statusText);
                      if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                      alertMessPopup("Registration error. Please try again.");
                    },
                  });
                });
              }

              // --- FORGOT PASSWORD - SEND OTP LOGIC ---
              const $forgotOtpBtn = $("#popupForgotOtpBtn");
              let otpInterval; // Keep track of the interval timer
              if ($forgotOtpBtn.length && $forgotPasswordView.length) {
                $forgotOtpBtn.on("click", function (e) {
                  e.preventDefault();
                  $forgotPasswordView.find(".alert-toast").empty().hide();
                  let phone = $forgotPasswordView
                    .find("#forgotUsername")
                    .val()
                    ?.trim();
                  let $button = $(this);
                  if (!phone || !/^\d{10}$/.test(phone)) {
                    alertMessPopup("Please enter a valid 10-digit phone number.");
                    return;
                  }

                  $button
                    .prop("disabled", true)
                    .addClass("block-click")
                    .text("Sending...");
                  let count = 30;
                  clearInterval(otpInterval); // Clear previous interval if any
                  otpInterval = setInterval(() => {
                    // Store interval ID
                    count--;
                    if (count > 0) {
                      $button.text(`Resend (${count}s)`);
                    } else {
                      clearInterval(otpInterval);
                      $button
                        .prop("disabled", false)
                        .removeClass("block-click")
                        .text("Send");
                    }
                  }, 1000);

                  $.ajax({
                    type: "POST",
                    url: "/api/sent/otp/verify/reset",
                    data: { phone: phone },
                    dataType: "json",
                    success: function (response) {
                      alertMessPopup(response.message || "OTP request sent.");
                      if (response.status !== true) {
                        clearInterval(otpInterval);
                        $button
                          .prop("disabled", false)
                          .removeClass("block-click")
                          .text("Send");
                      }
                    },
                    error: function (jqXHR) {
                      console.error("Forgot OTP AJAX Error:", jqXHR.statusText);
                      alertMessPopup("Error sending OTP.");
                      clearInterval(otpInterval);
                      $button
                        .prop("disabled", false)
                        .removeClass("block-click")
                        .text("Send");
                    },
                  });
                });
              }

              // --- FORGOT PASSWORD - RESET SUBMISSION LOGIC ---
              const $forgotSubmitBtn = $("#popupForgotSubmitBtn");
              if ($forgotSubmitBtn.length && $forgotPasswordView.length) {
                $forgotSubmitBtn.on("click", function (e) {
                  e.preventDefault();
                  $forgotPasswordView.find(".alert-toast").empty().hide();
                  let username = $forgotPasswordView
                    .find("#forgotUsername")
                    .val()
                    ?.trim();
                  let otp = $forgotPasswordView.find("#forgotOtp").val()?.trim();
                  let password = $forgotPasswordView
                    .find("#forgotNewPassword")
                    .val()
                    ?.trim();
                  if (!username || !otp || !password) {
                    alertMessPopup("Please fill in phone, OTP, and new password.");
                    return;
                  }
                  if (!/^\d{10}$/.test(username)) {
                    alertMessPopup("Please enter a valid 10-digit phone number.");
                    return;
                  }
                  if (!/^\d{4,6}$/.test(otp)) {
                    alertMessPopup("Please enter a valid OTP code.");
                    return;
                  }
                  if (
                    !/^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d@$!%*?&.\/]{8,}$/.test(password)
                  ) {
                    alertMessPopup(
                      "New password must be 8+ chars with letters & numbers."
                    );
                    return;
                  }
                  if ($loadingOverlay.length) $loadingOverlay.fadeIn(10);
                  $.ajax({
                    type: "POST",
                    url: "/api/resetPasword",
                    data: { username: username, otp: otp, pwd: password },
                    dataType: "json",
                    success: function (response) {
                      if (response.status === true) {
                        if ($loadingOverlay.length) $loadingOverlay.fadeOut(100);
                        alertMessPopup(
                          response.message ||
                          "Password reset successful! Please login."
                        );
                        setTimeout(() => {
                          $forgotPasswordView.fadeOut(150, function () {
                            $(this).removeClass("active");
                            $loginView.find('input[name="username"]').val(username);
                            $loginView.find("#passwordfield").val("");
                            $loginView.find(".alert-toast").empty().hide();
                            $loginView.fadeIn(150).addClass("active");
                          });
                        }, 2000);
                      } else {
                        if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                        alertMessPopup(response.message || "Password reset failed.");
                      }
                    },
                    error: function (jqXHR) {
                      console.error("Reset Password AJAX Error:", jqXHR.statusText);
                      if ($loadingOverlay.length) $loadingOverlay.fadeOut(300);
                      alertMessPopup("Error resetting password.");
                    },
                  });
                });
              }

              // --- Auto-fill invite code ---
              try {
                var url = new URL(window.location.href);
                var c = url.searchParams.get("r_code");
                if (c && $registerView.length) {
                  $registerView.find("#inviteCode").val(c);
                }
              } catch (e) {
                console.warn("Could not parse URL for r_code:", e);
              }
            }); // End of $(document).ready()
          </script>
