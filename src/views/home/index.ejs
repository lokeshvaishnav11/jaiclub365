  <script>
  document.addEventListener("DOMContentLoaded", function () {

    const track = document.querySelector(".slider-track");
    const slides = document.querySelectorAll(".slider-track img");
    const prevBtn = document.querySelector(".prev");
    const nextBtn = document.querySelector(".next");
    const dotsContainer = document.querySelector(".slider-dots");

    // safety check
    if (!track || !slides.length || !dotsContainer) return;

    let index = 0;
    const total = slides.length;

    // create dots
    slides.forEach((_, i) => {
      const dot = document.createElement("span");
      if (i === 0) dot.classList.add("active");
      dot.addEventListener("click", () => moveTo(i));
      dotsContainer.appendChild(dot);
    });

    const dots = dotsContainer.querySelectorAll("span");

    function moveTo(i) {
      index = i;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach(d => d.classList.remove("active"));
      dots[index].classList.add("active");
    }

    nextBtn.addEventListener("click", () => {
      moveTo((index + 1) % total);
    });

    prevBtn.addEventListener("click", () => {
      moveTo((index - 1 + total) % total);
    });

    // --- ENHANCED LIVE WITHDRAWALS FEED LOGIC WITH ANIMATIONS ---
    const withdrawalsFeed = document.getElementById('withdrawals-feed');
    if (withdrawalsFeed) {
      const users = [
        'Iram S.', 'Pooja C.', 'Suresh K.', 'Salim M.', 'Subhash P.', 'Vishnu P.', 'Ram K.', 'Vijay B.', 'Jeet P.', 'Vidya N.',
        'Aluddin H.', 'Mrityunjay S.', 'Masheen Y.', 'Syamsunder G.', 'Girjesh K.', 'Narender S.', 'Sattaram J.', 'Amrik S.', 'Vishal K.', 'Yogesh S.',
        'Mangi R.', 'Habib K.', 'Nayan S.', 'Deepak R.', 'Sunil K.', 'Pradeep K.', 'Narayan R.', 'Suman V.', 'Rahul M.', 'Sabir A.',
        'Vikrant P.', 'Ravi K.', 'Amit S.', 'Priya M.', 'Neha R.', 'Rohan D.', 'Divya S.', 'Karan V.', 'Anjali T.', 'Mohit G.',
        'Sneha B.', 'Arjun K.', 'Kavita P.', 'Rajesh M.', 'Simran K.', 'Varun S.', 'Megha R.', 'Siddharth L.', 'Pallavi N.', 'Kunal J.'
      ];

      let userIndex = 0;
      const maxItems = 6;
      let animationQueue = [];

      // Get random amount between 1000 and 50000
      const getRandomAmount = () => Math.floor(Math.random() * (50000 - 1000) + 1000);

      // Get user initials for avatar
      const getUserInitials = (name) => {
        const parts = name.split(' ');
        return parts.map(p => p[0]).join('');
      };

      // Format time ago
      const getTimeAgo = () => {
        const seconds = Math.floor(Math.random() * 60);
        if (seconds < 10) return 'Just now';
        if (seconds < 60) return `${seconds}s ago`;
        return '1m ago';
      };

      // Animate number counter
      const animateCounter = (element, target) => {
        const duration = 800;
        const start = 0;
        const increment = target / (duration / 16);
        let current = start;

        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            current = target;
            clearInterval(timer);
          }
          element.textContent = '₹ ' + Math.floor(current).toLocaleString('en-IN');
        }, 16);
      };

      const showRandomWithdrawal = () => {
        const user = users[userIndex];
        const amount = getRandomAmount();
        const initials = getUserInitials(user);
        const timeAgo = getTimeAgo();

        const newItem = document.createElement('div');
        newItem.classList.add('withdrawal-item', 'new-entry');
        newItem.innerHTML = `
                  <div class="user-section">
                      <div class="user-avatar">${initials}</div>
                      <div class="user-info">
                          <span class="user">${user}</span>
                          <span class="timestamp">${timeAgo}</span>
                      </div>
                  </div>
                  <div class="amount-section">
                      <span class="amount">₹ 0</span>
                      <span class="status-badge">✓ SUCCESS</span>
                  </div>
              `;

        // Add with animation
        withdrawalsFeed.prepend(newItem);

        // Animate the counter
        const amountElement = newItem.querySelector('.amount');
        setTimeout(() => {
          animateCounter(amountElement, amount);
        }, 100);

        // Remove new-entry class after animation
        setTimeout(() => {
          newItem.classList.remove('new-entry');
        }, 1600);

        // Remove oldest item with animation if exceeds max
        if (withdrawalsFeed.children.length > maxItems) {
          const lastItem = withdrawalsFeed.lastElementChild;
          lastItem.classList.add('removing');

          setTimeout(() => {
            if (lastItem.parentNode) {
              lastItem.remove();
            }
          }, 500);
        }

        userIndex = (userIndex + 1) % users.length;
      };

      // Initial population with staggered animation
      for (let i = 0; i < maxItems; i++) {
        setTimeout(() => {
          showRandomWithdrawal();
        }, i * 150);
      }

      // Set interval to add new items every second
      setTimeout(() => {
        setInterval(showRandomWithdrawal, 1000);
      }, maxItems * 150 + 500);
    }

  });
</script>

